<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="BudgetApp" Language="1033" Version="0.1.0" Manufacturer="BudgetExcel" UpgradeCode="B2B3C2A6-7E9E-4E0B-AE1C-4C7A4F2F5D10">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="BudgetApp" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="BudgetApp" />
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="BudgetApp" Level="1">
      <ComponentGroupRef Id="BudgetAppComponents" />
    </Feature>

    <ComponentGroup Id="BudgetAppComponents">
      <Component Id="BudgetAppExecutable" Guid="{8F0C7A32-8B9E-4D1A-9B5D-9A7C1F7F2C1B}" Directory="INSTALLFOLDER">
        <File Id="BudgetdExe" Source="bin\budgetd.exe" KeyPath="yes" />
        <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuDir" Name="Budget Service" WorkingDirectory="INSTALLFOLDER" Icon="BudgetAppIcon" IconIndex="0" Advertise="no" />
        <RemoveFolder Id="RemoveStartMenuDir" Directory="ProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKLM" Key="Software\BudgetExcel\BudgetApp" Name="installed" Type="integer" Value="1" KeyPath="no" />
      </Component>
    </ComponentGroup>

    <Icon Id="BudgetAppIcon" SourceFile="bin\budgetd.exe" />
  </Product>
</Wix>
