<%= form_with(model: tag, class: "space-y-4") do |f| %>
  <% if tag.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md">
      <ul class="list-disc pl-5 text-sm text-red-800">
        <% tag.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
  </div>
  <div>
    <%= f.label :color, class: "block text-sm font-medium text-gray-700" %>
    <%= f.color_field :color, class: "mt-1 h-10 w-20" %>
  </div>
  <div>
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
