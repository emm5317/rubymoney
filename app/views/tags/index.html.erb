<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Tags</h1>
    <%= link_to "New Tag", new_tag_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(tag), class: "inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium hover:opacity-80", style: "background-color: #{tag.color}20; color: #{tag.color}; border: 1px solid #{tag.color}40;" do %>
          <%= tag.name %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden mt-6">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Badge</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Color</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @tags.each_with_index do |tag, index| %>
          <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %>">
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                <%= tag.name %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
              <%= link_to tag.name, tag_path(tag), class: "text-indigo-600 hover:text-indigo-900" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono"><%= tag.color %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= link_to "Edit", edit_tag_path(tag), class: "text-indigo-600 hover:text-indigo-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
