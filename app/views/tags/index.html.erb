<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Tags</h1>
    <%= link_to "New Tag", new_tag_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
  </div>

  <% if @tags.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tag</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Color</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @tags.each_with_index do |tag, index| %>
            <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to tag_path(tag), class: "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium hover:opacity-80", style: "background-color: #{tag.color}20; color: #{tag.color}; border: 1px solid #{tag.color}40;" do %>
                  <%= tag.name %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <span class="inline-flex items-center space-x-2">
                  <span class="w-4 h-4 rounded-full" style="background-color: <%= tag.color %>;"></span>
                  <span class="font-mono text-xs"><%= tag.color %></span>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "Edit", edit_tag_path(tag), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                <% other_tags = @tags.reject { |t| t.id == tag.id } %>
                <% if other_tags.any? %>
                  <%= form_with(url: merge_tags_path, method: :post, class: "inline-flex items-center gap-1", data: { turbo_confirm: "Merge \"#{tag.name}\" into the selected tag? This cannot be undone." }) do |f| %>
                    <%= f.hidden_field :source_id, value: tag.id %>
                    <%= f.select :target_id, other_tags.map { |t| [t.name, t.id] }, {}, class: "rounded-md border-gray-300 shadow-sm text-xs py-1 focus:border-indigo-500 focus:ring-indigo-500" %>
                    <%= f.submit "Merge", class: "px-2 py-1 text-xs bg-red-600 text-white font-medium rounded-md hover:bg-red-700 cursor-pointer" %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <p class="text-gray-500">No tags yet.</p>
      <%= link_to "Create your first tag", new_tag_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
    </div>
  <% end %>
</div>
