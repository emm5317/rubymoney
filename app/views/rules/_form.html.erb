<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: rule, class: "space-y-6") do |f| %>
    <% if rule.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(rule.errors.count, "error") %> prohibited this rule from being saved:</h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% rule.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :match_pattern, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :match_pattern, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :match_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :match_type, [["Contains", "contains"], ["Exact", "exact"], ["Starts With", "starts_with"], ["Regex", "regex"]], { prompt: "Select match type" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :category_id, class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :category_id, Category.sorted, :id, :name, { prompt: "Select category" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :priority, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :priority, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
