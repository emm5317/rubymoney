<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: rule, class: "space-y-6") do |f| %>
    <% if rule.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% rule.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= f.label :match_field, "Match Field", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :match_field, [["Description", "description"], ["Normalized Description", "normalized_desc"], ["Amount", "amount_field"]], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :match_type, "Match Type", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :match_type, [["Contains", "contains"], ["Exact", "exact"], ["Starts With", "starts_with"], ["Regex", "regex"], ["Greater Than", "gt"], ["Less Than", "lt"], ["Between", "between"]], { prompt: "Select match type" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= f.label :match_value, "Match Value", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :match_value, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g. STARBUCKS or 5000 (cents)" %>
        <p class="mt-1 text-xs text-gray-500">For amount rules, enter value in cents.</p>
      </div>

      <div>
        <%= f.label :match_value_upper, "Upper Value (for Between)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :match_value_upper, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g. 10000 (cents)" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :category_id, Category.sorted, :id, :name, { prompt: "Select category" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :priority, class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :priority, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500">Higher priority rules win when multiple match.</p>
      </div>
    </div>

    <div class="flex items-center space-x-8">
      <label class="flex items-center space-x-2">
        <%= f.check_box :enabled, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
        <span class="text-sm text-gray-700">Enabled</span>
      </label>

      <label class="flex items-center space-x-2">
        <%= f.check_box :apply_retroactive, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
        <span class="text-sm text-gray-700">Apply retroactively to existing uncategorized transactions</span>
      </label>
    </div>

    <div>
      <%= f.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
