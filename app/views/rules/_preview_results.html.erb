<div class="bg-white shadow rounded-lg overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h3 class="text-sm font-semibold text-gray-900">
      <% if error_message.present? %>
        Preview unavailable
      <% elsif transactions.any? %>
        <%= transactions.size %> matching transaction<%= transactions.size == 1 ? "" : "s" %> found
      <% else %>
        No matching transactions found
      <% end %>
    </h3>
  </div>

  <% if error_message.present? %>
    <div class="p-8 text-center">
      <p class="text-red-600"><%= error_message %></p>
    </div>
  <% elsif transactions.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Account</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% transactions.each_with_index do |txn, index| %>
          <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
            <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500"><%= txn.date.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-900"><%= txn.description %></td>
            <td class="px-6 py-3 whitespace-nowrap text-sm text-right <%= txn.debit? ? 'text-red-600' : 'text-green-600' %>">
              <%= number_to_currency(txn.amount) %>
            </td>
            <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500"><%= txn.account.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-gray-500">Try adjusting your match field, type, or value.</p>
    </div>
  <% end %>
</div>
