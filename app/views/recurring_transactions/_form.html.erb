<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: recurring_transaction, class: "space-y-6") do |form| %>
    <% if recurring_transaction.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800">
          <%= pluralize(recurring_transaction.errors.count, "error") %> prohibited this record from being saved:
        </h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% recurring_transaction.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= form.label :frequency, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :frequency, RecurringTransaction.frequencies.keys.map { |f| [f.titleize, f] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
        <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "Uncategorized" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :status, RecurringTransaction.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <p class="text-sm text-gray-500">Description pattern: <code class="bg-gray-100 px-1 py-0.5 rounded text-xs"><%= recurring_transaction.description_pattern %></code></p>
      <p class="text-sm text-gray-500 mt-1">Account: <%= recurring_transaction.account.name %></p>
    </div>

    <div>
      <%= form.submit "Update", class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
