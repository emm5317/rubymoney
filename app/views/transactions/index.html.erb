<div class="max-w-7xl mx-auto px-4 py-8" data-controller="bulk-select">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Transactions</h1>
    <div class="flex space-x-3">
      <% uncategorized_count = Transaction.joins(:account).where(accounts: { user_id: current_user.id }).uncategorized.count %>
      <%= link_to uncategorized_transactions_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-md hover:bg-gray-50" do %>
        Uncategorized
        <% if uncategorized_count > 0 %>
          <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800"><%= uncategorized_count %></span>
        <% end %>
      <% end %>
      <%= link_to "New Transaction", new_transaction_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>

  <%= render "filters" %>

  <% if @transactions.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left">
              <input type="checkbox" data-bulk-select-target="selectAll" data-action="change->bulk-select#toggleAll" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tags</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Account</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @transactions.each_with_index do |transaction, index| %>
            <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors <%= transaction.is_transfer? ? 'opacity-60' : '' %>">
              <td class="px-4 py-4">
                <input type="checkbox" value="<%= transaction.id %>" data-bulk-select-target="checkbox" data-action="change->bulk-select#toggle" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= transaction.date.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= link_to transaction.description, transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right <%= transaction.debit? ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(transaction.amount) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= render "category_cell", transaction: transaction %></td>
              <td class="px-6 py-4 text-sm"><%= render "tag_cell", transaction: transaction, tags: @tags %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= transaction.account.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "Edit", edit_transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <%== pagy_nav(@pagy) %>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <% if filter_active? %>
        <p class="text-gray-500">No transactions match your filters.</p>
        <%= link_to "Clear filters", transactions_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
      <% else %>
        <p class="text-gray-500">No transactions yet.</p>
        <%= link_to "Add your first transaction", new_transaction_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
      <% end %>
    </div>
  <% end %>

  <%= render "bulk_actions_bar" %>
</div>
