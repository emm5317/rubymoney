<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: transaction, class: "space-y-6") do |f| %>
    <% if transaction.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(transaction.errors.count, "error") %> prohibited this transaction from being saved:</h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% transaction.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :account_id, class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :account_id, Account.all, :id, :name, { prompt: "Select account" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :date, class: "block text-sm font-medium text-gray-700" %>
      <%= f.date_field :date, value: transaction.date || Date.current, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :description, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :amount, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :amount, step: 0.01, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :transaction_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :transaction_type, [["Debit", "debit"], ["Credit", "credit"]], { prompt: "Select type" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :category_id, class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :category_id, Category.sorted, :id, :name, { prompt: "Select category", include_blank: "Uncategorized" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status, [["Pending", "pending"], ["Cleared", "cleared"], ["Reconciled", "reconciled"]], {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :tag_ids, "Tags", class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_check_boxes :tag_ids, Tag.sorted, :id, :name do |b| %>
        <div class="flex items-center mt-1">
          <%= b.check_box class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
          <%= b.label class: "ml-2 text-sm text-gray-700" %>
        </div>
      <% end %>
    </div>

    <div>
      <%= f.label :memo, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :memo, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
