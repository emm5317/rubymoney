<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Transaction Detail</h1>
    <div class="flex space-x-3">
      <%= link_to "Edit", edit_transaction_path(@transaction), class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
      <%= button_to "Delete", transaction_path(@transaction), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "inline-flex items-center px-4 py-2 bg-red-600 text-white font-medium rounded-md hover:bg-red-700" %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
      <div>
        <dt class="text-sm font-medium text-gray-500">Date</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @transaction.date.strftime("%B %d, %Y") %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Description</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @transaction.description %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Amount</dt>
        <dd class="mt-1 text-sm font-semibold <%= @transaction.debit? ? 'text-red-600' : 'text-green-600' %>">
          <%= number_to_currency(@transaction.amount) %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Type</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @transaction.transaction_type.titleize %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Account</dt>
        <dd class="mt-1 text-sm text-gray-900">
          <%= link_to @transaction.account.name, account_path(@transaction.account), class: "text-indigo-600 hover:text-indigo-900" %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Category</dt>
        <dd class="mt-1 text-sm">
          <% if @transaction.category %>
            <span class="inline-flex items-center">
              <span class="w-2 h-2 rounded-full mr-1.5" style="background-color: <%= @transaction.category.color %>;"></span>
              <%= @transaction.category.name %>
            </span>
            <% if @transaction.auto_categorized? %>
              <span class="ml-1 text-xs text-gray-400">(auto)</span>
            <% end %>
          <% else %>
            <span class="text-gray-400 italic">Uncategorized</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Status</dt>
        <dd class="mt-1"><%= transaction_status_badge(@transaction.status) %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Tags</dt>
        <dd class="mt-1 flex flex-wrap gap-1">
          <% if @transaction.tags.any? %>
            <% @transaction.tags.each do |tag| %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                <%= tag.name %>
              </span>
            <% end %>
          <% else %>
            <span class="text-gray-400 text-sm">None</span>
          <% end %>
        </dd>
      </div>
      <% if @transaction.memo.present? %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-gray-500">Memo</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @transaction.memo %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%# Recurring badge %>
  <% if @recurring_match %>
    <div class="mt-4 bg-indigo-50 border border-indigo-200 rounded-lg p-4 flex items-center justify-between">
      <div class="flex items-center">
        <svg class="w-5 h-5 text-indigo-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span class="text-sm text-indigo-800">Part of recurring: <strong><%= @recurring_match.title %></strong> (<%= @recurring_match.frequency.titleize %>)</span>
      </div>
      <%= link_to "View", recurring_transaction_path(@recurring_match), class: "text-sm text-indigo-600 hover:text-indigo-900 font-medium" %>
    </div>
  <% end %>

  <%# Transfer section %>
  <div class="mt-6 bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Transfer</h2>

    <% if @transaction.is_transfer? && @transaction.transfer_pair %>
      <% pair = @transaction.transfer_pair %>
      <div class="flex items-center justify-between p-3 bg-gray-50 rounded-md">
        <div class="text-sm">
          <span class="font-medium"><%= pair.description %></span>
          <span class="text-gray-500 ml-2"><%= pair.account.name %></span>
          <span class="ml-2 <%= pair.debit? ? 'text-red-600' : 'text-green-600' %>"><%= number_to_currency(pair.amount) %></span>
          <span class="text-gray-400 ml-2"><%= pair.date.strftime("%b %d, %Y") %></span>
        </div>
        <%= button_to "Unlink", unlink_transfer_transaction_path(@transaction), method: :delete, class: "px-3 py-1 text-sm bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300", data: { turbo_confirm: "Unlink this transfer pair?" } %>
      </div>
    <% elsif @transfer_candidates&.any? %>
      <p class="text-sm text-gray-500 mb-3">Potential transfer matches:</p>
      <div class="space-y-2">
        <% @transfer_candidates.each do |candidate| %>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-md">
            <div class="text-sm">
              <span class="font-medium"><%= candidate.description %></span>
              <span class="text-gray-500 ml-2"><%= candidate.account.name %></span>
              <span class="ml-2 <%= candidate.debit? ? 'text-red-600' : 'text-green-600' %>"><%= number_to_currency(candidate.amount) %></span>
              <span class="text-gray-400 ml-2"><%= candidate.date.strftime("%b %d, %Y") %></span>
            </div>
            <%= button_to "Link", link_transfer_transaction_path(@transaction, transfer_pair_id: candidate.id), method: :post, class: "px-3 py-1 text-sm bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400">No transfer matches found.</p>
    <% end %>
  </div>

  <div class="mt-4 flex items-center space-x-4">
    <%= link_to "Back to Transactions", transactions_path, class: "text-indigo-600 hover:text-indigo-900 text-sm" %>
    <%= link_to "Create Rule", create_rule_transaction_path(@transaction), class: "text-indigo-600 hover:text-indigo-900 text-sm", data: { turbo_method: :post } %>
  </div>
</div>
