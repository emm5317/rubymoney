<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Uncategorized Transactions</h1>
      <p class="text-sm text-gray-500 mt-1"><%= @uncategorized_count %> transactions need categorization</p>
    </div>
    <%= link_to "All Transactions", transactions_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-md hover:bg-gray-50" %>
  </div>

  <div class="bg-white shadow rounded-lg p-4 mb-6">
    <%= form_with(url: uncategorized_transactions_path, method: :get, class: "flex flex-wrap items-end gap-4", data: { turbo_frame: "_top" }) do |f| %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>

      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
        <%= text_field_tag :search, params[:search], placeholder: "Search descriptions...", class: "rounded-md border-gray-300 shadow-sm text-sm py-1.5 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= submit_tag "Filter", class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
      </div>
      <% if params[:search].present? %>
        <div>
          <%= link_to "Clear", uncategorized_transactions_path, class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @transactions.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden" data-controller="bulk-select">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left">
              <input type="checkbox" data-bulk-select-target="selectAll" data-action="change->bulk-select#toggleAll"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= sort_link("date", "Date") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= sort_link("description", "Description") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= sort_link("amount_cents", "Amount", align_right: true) %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Account</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tags</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @transactions.each_with_index do |transaction, index| %>
            <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <input type="checkbox" value="<%= transaction.id %>" data-bulk-select-target="checkbox" data-action="change->bulk-select#toggle"
                       class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= transaction.date.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= link_to transaction.description, transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right <%= transaction.debit? ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(transaction.amount) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= transaction.account.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm"><%= render "category_cell", transaction: transaction %></td>
              <td class="px-6 py-4 text-sm"><%= render "tag_cell", transaction: transaction, tags: @tags %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                <%= link_to "Create Rule", create_rule_transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900", data: { turbo_method: :post } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%= render "bulk_actions_bar" %>
    </div>

    <div class="mt-4">
      <%== pagy_nav(@pagy) %>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <% if params[:search].present? %>
        <p class="text-gray-500">No uncategorized transactions match your search.</p>
        <%= link_to "Clear search", uncategorized_transactions_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
      <% else %>
        <p class="text-green-600 font-medium">All transactions are categorized!</p>
        <%= link_to "View all transactions", transactions_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
      <% end %>
    </div>
  <% end %>
</div>
