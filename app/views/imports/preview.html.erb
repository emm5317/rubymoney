<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Preview: <%= @import.file_name %></h1>
  <div class="bg-white shadow rounded-lg p-6">
    <p class="text-gray-500 mb-4">Review the parsed transactions below before confirming.</p>
    <% if @import.preview_data.present? %>
      <div class="overflow-x-auto">
        <p class="text-sm text-gray-500"><%= @import.preview_data.size %> transactions parsed</p>
      </div>
    <% else %>
      <p class="text-gray-500">No preview data available yet.</p>
    <% end %>
    <div class="mt-6 flex space-x-4">
      <%= button_to "Confirm Import", confirm_account_import_path(@account, @import), method: :post, class: "px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700" %>
      <%= link_to "Cancel", account_imports_path(@account), class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300" %>
    </div>
  </div>
</div>
