<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Import Statement for <%= @account.name %></h1>

  <div class="bg-white shadow rounded-lg p-6">
    <%= form_with(model: [@account, @import], class: "space-y-6") do |f| %>
      <% if @import.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @import.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :file, "Statement File", class: "block text-sm font-medium text-gray-700" %>
        <%= f.file_field :file, accept: ".csv,.ofx,.qfx", class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
        <p class="mt-1 text-xs text-gray-500">Supported formats: CSV, OFX, QFX</p>
      </div>

      <div>
        <%= f.label :file_type, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :file_type, Import.file_types.keys.select { |t| t != "pdf" }.map { |t| [t.upcase, t] }, { prompt: "Auto-detect from file extension" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500">Leave blank to auto-detect from file extension.</p>
      </div>

      <div class="flex items-center space-x-4">
        <%= f.submit "Upload & Preview", class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
        <%= link_to "Cancel", account_imports_path(@account), class: "text-gray-600 hover:text-gray-900 text-sm" %>
      </div>
    <% end %>
  </div>
</div>
