<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Import Statement for <%= @account.name %></h1>
  <%= form_with(model: [@account, @import], class: "space-y-4") do |f| %>
    <div>
      <%= f.label :file_name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :file_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :file_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :file_type, Import.file_types.keys.map { |t| [t.upcase, t] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.submit "Upload", class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
