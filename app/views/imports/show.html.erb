<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Import: <%= @import.file_name %></h1>
    <% if @import.previewing? %>
      <%= link_to "Review Preview", preview_account_import_path(@account, @import), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-6 space-y-6">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      <div>
        <p class="text-sm text-gray-500">Status</p>
        <span class="inline-flex mt-1 px-2.5 py-0.5 rounded-full text-xs font-medium
          <%= case @import.status
              when 'completed' then 'bg-green-100 text-green-800'
              when 'failed' then 'bg-red-100 text-red-800'
              when 'processing' then 'bg-blue-100 text-blue-800'
              when 'previewing' then 'bg-yellow-100 text-yellow-800'
              else 'bg-gray-100 text-gray-800'
              end %>">
          <%= @import.status.titleize %>
        </span>
      </div>
      <div>
        <p class="text-sm text-gray-500">File Type</p>
        <p class="mt-1 font-semibold"><%= @import.file_type.upcase %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Total Rows</p>
        <p class="mt-1 font-semibold"><%= @import.total_rows %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Imported</p>
        <p class="mt-1 font-semibold text-green-600"><%= @import.imported_count %></p>
      </div>
      <div>
        <p class="text-sm text-gray-500">Skipped</p>
        <p class="mt-1 font-semibold text-yellow-600"><%= @import.skipped_count %></p>
      </div>
    </div>

    <% if @import.error_count.to_i > 0 && @import.error_log.present? %>
      <div class="border-t pt-4">
        <h3 class="text-sm font-medium text-red-800 mb-2">Errors (<%= @import.error_count %>)</h3>
        <div class="bg-red-50 rounded-md p-3 max-h-48 overflow-y-auto">
          <% @import.error_log.each do |err| %>
            <p class="text-xs text-red-700"><%= err["error"] || err[:error] %></p>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @import.completed? %>
      <div class="border-t pt-4 flex items-center justify-between">
        <p class="text-sm text-gray-500">Completed <%= @import.completed_at&.strftime("%B %d, %Y at %l:%M %p") %></p>
        <%= button_to "Rollback Import", rollback_account_import_path(@account, @import), method: :post,
          class: "px-4 py-2 bg-red-600 text-white font-medium rounded-md hover:bg-red-700",
          data: { turbo_confirm: "This will delete all #{@import.imported_count} transactions from this import. Are you sure?" } %>
      </div>
    <% end %>
  </div>

  <%= link_to "Back to Imports", account_imports_path(@account), class: "mt-4 inline-block text-indigo-600 hover:text-indigo-900 text-sm" %>
</div>
