<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Imports for <%= @account.name %></h1>
    <%= link_to "New Import", new_account_import_path(@account), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
  </div>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">File</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Imported</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @imports.each do |import| %>
          <tr>
            <td class="px-6 py-4 text-sm"><%= link_to import.file_name, account_import_path(@account, import), class: "text-indigo-600 hover:text-indigo-900" %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= import.file_type.upcase %></td>
            <td class="px-6 py-4 text-sm">
              <span class="px-2 py-1 text-xs rounded-full <%= import.completed? ? 'bg-green-100 text-green-800' : import.failed? ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %>">
                <%= import.status.titleize %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= import.imported_count %> / <%= import.total_rows %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= import.created_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
