<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Imports for <%= @account.name %></h1>
    <%= link_to "New Import", new_account_import_path(@account), class: "px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
  </div>

  <% if @imports.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">File</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Result</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @imports.each_with_index do |import, index| %>
            <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
              <td class="px-6 py-4 text-sm">
                <%= link_to import.file_name, account_import_path(@account, import), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= import.file_type.upcase %></td>
              <td class="px-6 py-4 text-sm"><%= import_status_badge(import.status) %></td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <% if import.completed? || import.failed? %>
                  <%= import.imported_count %> imported, <%= import.skipped_count %> skipped
                <% elsif import.previewing? %>
                  <%= import.total_rows %> rows parsed
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= import.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <p class="text-gray-500">No imports yet for this account.</p>
      <%= link_to "Import your first statement", new_account_import_path(@account), class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
    </div>
  <% end %>

  <%= link_to "Back to Account", account_path(@account), class: "mt-4 inline-block text-indigo-600 hover:text-indigo-900 text-sm" %>
</div>
