<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
    <%= link_to "New Category", new_category_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
  </div>

  <% if @categories.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Position</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @categories.each_with_index do |category, index| %>
            <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= link_to category_path(category), class: "inline-flex items-center text-indigo-600 hover:text-indigo-900" do %>
                  <span class="w-3 h-3 rounded-full mr-2" style="background-color: <%= category.color %>;"></span>
                  <%= category.name %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= category.position %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                <%= link_to "Edit", edit_category_path(category), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                <% other_categories = @categories.reject { |c| c.id == category.id } %>
                <% if other_categories.any? %>
                  <%= form_with(url: merge_categories_path, method: :post, class: "inline-flex items-center gap-1", data: { turbo_confirm: "Merge \"#{category.name}\" into the selected category? This cannot be undone." }) do |f| %>
                    <%= f.hidden_field :source_id, value: category.id %>
                    <%= f.select :target_id, other_categories.map { |c| [c.name, c.id] }, {}, class: "rounded-md border-gray-300 shadow-sm text-xs py-1 focus:border-indigo-500 focus:ring-indigo-500" %>
                    <%= f.submit "Merge", class: "px-2 py-1 text-xs bg-red-600 text-white font-medium rounded-md hover:bg-red-700 cursor-pointer" %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <p class="text-gray-500">No categories yet.</p>
      <%= link_to "Create your first category", new_category_path, class: "mt-2 inline-block text-indigo-600 hover:text-indigo-900" %>
    </div>
  <% end %>
</div>
