<%= form_with(model: budget, class: "space-y-4") do |f| %>
  <% if budget.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md">
      <ul class="list-disc pl-5 text-sm text-red-800">
        <% budget.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= f.label :category_id, class: "block text-sm font-medium text-gray-700" %>
    <%= f.collection_select :category_id, Category.sorted, :id, :name, { prompt: "Select category" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :month, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :month, (1..12).map { |m| [Date::MONTHNAMES[m], m] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
    <div>
      <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :year, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>
  </div>
  <div>
    <%= f.label :amount_cents, "Amount (cents)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.number_field :amount_cents, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
  </div>
  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
  </div>
  <div>
    <%= f.submit class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
