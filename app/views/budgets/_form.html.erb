<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: budget, class: "space-y-6") do |f| %>
    <% if budget.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(budget.errors.count, "error") %> prohibited this budget from being saved:</h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% budget.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :category_id, class: "block text-sm font-medium text-gray-700" %>
      <%= f.collection_select :category_id, Category.sorted, :id, :name, { prompt: "Select category" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <%= f.label :month, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :month, (1..12).map { |m| [Date::MONTHNAMES[m], m] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :year, class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :year, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :amount_cents, "Amount (cents)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :amount_cents, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      <p class="mt-1 text-xs text-gray-500">Enter the budget amount in cents (e.g., 50000 = $500.00).</p>
    </div>

    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
