<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Budgets</h1>
    <%= link_to "New Budget", new_budget_path, class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
  </div>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Month</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @budgets.each do |budget| %>
          <tr>
            <td class="px-6 py-4 text-sm text-gray-900"><%= budget.category.name %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= Date.new(budget.year, budget.month).strftime("%B %Y") %></td>
            <td class="px-6 py-4 text-sm text-gray-900">$<%= '%.2f' % budget.display_amount %></td>
            <td class="px-6 py-4 text-sm space-x-2">
              <%= link_to "Edit", edit_budget_path(budget), class: "text-indigo-600 hover:text-indigo-900" %>
              <%= button_to "Delete", budget_path(budget), method: :delete, class: "text-red-600 hover:text-red-900", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
