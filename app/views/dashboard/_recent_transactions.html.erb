<div class="bg-white shadow rounded-lg overflow-hidden mb-8">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
    <h2 class="text-lg font-semibold text-gray-900">Recent Transactions</h2>
    <div class="flex items-center space-x-3">
      <%= link_to "Import", import_start_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 font-medium rounded-md hover:bg-gray-50" %>
      <%= link_to "Add Transaction", new_transaction_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  </div>

  <% if @recent_transactions.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Account</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @recent_transactions.each_with_index do |transaction, index| %>
          <tr class="<%= index.even? ? 'bg-white' : 'bg-gray-50' %> hover:bg-gray-100 transition-colors">
            <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500"><%= transaction.date.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-3 whitespace-nowrap text-sm">
              <%= link_to transaction.description, transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900" %>
            </td>
            <td class="px-6 py-3 whitespace-nowrap text-sm text-right <%= transaction.debit? ? 'text-red-600' : 'text-green-600' %>">
              <%= number_to_currency(transaction.amount) %>
            </td>
            <td class="px-6 py-3 whitespace-nowrap text-sm"><%= category_label(transaction.category) %></td>
            <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500"><%= transaction.account.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="px-6 py-3 bg-gray-50 text-right">
      <%= link_to "View all transactions →", transactions_path, class: "text-sm text-indigo-600 hover:text-indigo-900" %>
    </div>
  <% else %>
    <div class="p-8 text-center">
      <p class="text-gray-500">No transactions yet. Import a statement to get started.</p>
    </div>
  <% end %>
</div>
