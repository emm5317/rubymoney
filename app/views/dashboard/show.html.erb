<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <% if @accounts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <% @accounts.each do |account| %>
        <div class="bg-white rounded-lg shadow p-6">
          <h3 class="text-sm font-medium text-gray-500"><%= account.institution %></h3>
          <p class="text-lg font-semibold text-gray-900"><%= account.name %></p>
          <p class="text-2xl font-bold mt-2 <%= account.current_balance_cents >= 0 ? 'text-green-600' : 'text-red-600' %>">
            $<%= '%.2f' % account.display_balance %>
          </p>
          <span class="inline-block mt-2 px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-600">
            <%= account.account_type.titleize %>
          </span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <h3 class="text-lg font-medium text-gray-900">Welcome to Finance Reconciler</h3>
      <p class="mt-2 text-gray-500">Get started by creating an account and importing your first statement.</p>
      <%= link_to "Create Account", new_account_path, class: "mt-4 inline-block px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
