<div class="max-w-7xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Dashboard</h1>

  <% if @accounts.any? %>
    <%= render "period_nav" %>
    <%= render "summary_stats" %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <%= render "category_chart" %>
      <%= render "trends_chart" %>
    </div>

    <%= render "transactions_drilldown" %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <%= render "income_vs_expenses" %>
      <%= render "net_worth_chart" %>
    </div>

    <%= render "budget_progress" %>
    <%= render "top_merchants" %>
    <%= render "tag_spending" %>
    <%= render "accounts_overview" %>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow p-8">
      <h3 class="text-lg font-medium text-gray-900">Welcome to Finance Reconciler</h3>
      <p class="mt-2 text-sm text-gray-500">Get started by creating an account and importing your first statement.</p>
      <%= link_to "Create Account", new_account_path, class: "mt-4 inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
