<div class="bg-white shadow rounded-lg p-6">
  <%= form_with(model: account, class: "space-y-6") do |f| %>
    <% if account.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(account.errors.count, "error") %> prohibited this account from being saved:</h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% account.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :account_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :account_type, [["Checking", "checking"], ["Savings", "savings"], ["Credit Card", "credit_card"], ["Investment", "investment"]], { prompt: "Select type" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :institution, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :institution, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :currency, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :currency, value: account.currency || "USD", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white font-medium rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
